{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=IdentityHubDb;Username=nimaniko;Password=your_password_here"
  },
  "AppSettings": {
    "AppUrl": "https://yourdomain.com",
    "JwtSecret": "your-super-secret-key-minimum-32-characters-long-for-production",
    "JwtExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Email": {
    "Provider": "SendGrid",
    "SendGrid": {
      "ApiKey": "your-sendgrid-api-key",
      "FromEmail": "noreply@yourdomain.com",
      "FromName": "IdentityHub"
    },
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "your-email@gmail.com",
      "Password": "your-app-password"
    }
  },
  "Ldap": {
    "Enabled": true,
    "Server": "ldap://your-ldap-server.com",
    "Port": 389,
    "BaseDn": "dc=company,dc=com",
    "Username": "cn=admin,dc=company,dc=com",
    "Password": "your-ldap-password",
    "UseSSL": false
  },
  "Security": {
    "PasswordPolicy": {
      "MinimumLength": 12,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigits": true,
      "RequireSpecialCharacters": true,
      "PasswordHistoryCount": 3,
      "PasswordExpirationDays": 90
    },
    "AccountLockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 15
    },
    "Otp": {
      "Length": 6,
      "ExpirationMinutes": 5,
      "MaxAttempts": 5
    },
    "CORS": {
      "AllowedOrigins": [
        "https://yourdomain.com",
        "https://app.yourdomain.com"
      ],
      "AllowedMethods": ["GET", "POST", "PUT", "DELETE"],
      "AllowedHeaders": ["Content-Type", "Authorization"]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "IdentityHub": "Information"
    }
  },
  "AllowedHosts": "*"
}
